# ── Server ────────────────────────────────────────────────────────────────────
PORT=9000
DATA_PATH=/data

# ── Storage ───────────────────────────────────────────────────────────────────
SQLITE_PATH=/data/ragpack.db
LANCEDB_PATH=/data/lancedb

# ── Defaults ──────────────────────────────────────────────────────────────────
# Which provider to use for embeddings (openai | ollama | tei | huggingface)
DEFAULT_EMBED_PROVIDER=ollama
# Which provider to use for LLM completions (openai | ollama | anthropic)
DEFAULT_LLM_PROVIDER=ollama

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_LLM_MODEL=gpt-4o-mini

# ── Ollama ────────────────────────────────────────────────────────────────────
# docker compose --profile ollama up
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2:1b

# ── Anthropic ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── TEI (self-hosted HuggingFace Text Embeddings Inference) ───────────────────
# docker compose --profile tei up
# TEI_BASE_URL=http://tei:80
# TEI_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── HuggingFace Inference API ─────────────────────────────────────────────────
# HF_API_KEY=hf_...
# HF_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── RAG ───────────────────────────────────────────────────────────────────────
# Default prompt template used when no prompt_slug is specified in a RAG request.
# Built-in options: basic_rag | rag_with_citations | concise_rag
# DEFAULT_PROMPT_SLUG=basic_rag

# ── Ingester ──────────────────────────────────────────────────────────────────
WORKER_COUNT=5
EMBED_RATE_LIMIT=10  # max embedding API calls per second
MAX_UPLOAD_SIZE_MB=20  # max file size for multipart uploads

# Chunking defaults (can be overridden per collection via the API)
# CHUNK_STRATEGY=auto   # auto | unit | paragraph | sliding_window | section | row_group
# CHUNK_SIZE=2000       # max characters per chunk
# CHUNK_OVERLAP=200     # characters carried into the next chunk for context continuity

# ── Collection auto-refresh ───────────────────────────────────────────────────
# Auto-refresh is opt-in per collection (off by default) — these just bound/seed
# the interval a collection can be configured with, via PATCH /collections/:id.
# MIN_COLLECTION_REFRESH=900       # shortest allowed interval, in seconds (15 min)
# DEFAULT_COLLECTION_REFRESH=3600  # suggested starting value for the admin UI; not enforced

# ── AWS (only needed for s3:// file URIs) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
