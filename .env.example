# ── Server ────────────────────────────────────────────────────────────────────
PORT=9000
DATA_PATH=/data

# ── Storage ───────────────────────────────────────────────────────────────────
SQLITE_PATH=/data/ragpack.db
LANCEDB_PATH=/data/lancedb

# ── Embedder ──────────────────────────────────────────────────────────────────
# DEFAULT_EMBED_PROVIDER picks the default when no embed_model is specified on collection create.
# All configured providers are always registered — collections can use any of them explicitly.
# Providers: openai | ollama | tei | huggingface
# Run with: docker compose --profile tei up
#           docker compose --profile ollama up
DEFAULT_EMBED_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama — docker compose --profile ollama
OLLAMA_EMBED_MODEL=nomic-embed-text

# TEI (HuggingFace Text Embeddings Inference) — docker compose --profile tei
# Any HuggingFace feature-extraction model with ONNX files. Recommended: BAAI/bge-small-en-v1.5
TEI_BASE_URL=http://localhost:8080
TEI_EMBED_MODEL=BAAI/bge-small-en-v1.5

# HuggingFace Inference API (cloud free tier, no self-hosting)
# HF_API_KEY=hf_...
# HF_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── Ingester ──────────────────────────────────────────────────────────────────
WORKER_COUNT=5
EMBED_RATE_LIMIT=10  # max embedding API calls per second

# Chunking defaults (can be overridden per collection via the API)
# CHUNK_STRATEGY=auto   # auto | unit | paragraph | sliding_window | section | row_group
# CHUNK_SIZE=2000       # max characters per chunk
# CHUNK_OVERLAP=200     # characters carried into the next chunk for context continuity

# ── AWS (only needed for s3:// file URIs) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
